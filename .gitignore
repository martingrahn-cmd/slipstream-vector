# OS junk
.DS_Store
**/.DS_Store

# Editor / tooling (launch.json is committed so the dev server config
# travels with the repo; everything else in .claude/ stays machine-local)
.claude/*
!.claude/launch.json
.vscode/
.idea/

# Working files (contact sheets, batch-render output — never ship these)
exports/

# Dependencies (this is a CDN import-map project with no build step, but
# future-proof in case a toolchain is added later)
node_modules/

# (Music is committed — Martin's own compositions ship with the game.)
